// =============================================================================
// shell.qml — QuickShell Settings Dashboard Entry Point
// =============================================================================
//
// Full-screen transparent overlay. The dashboard is a 700×650 centered card
// that drops down from the top and settles with its top edge just below the
// bar (SettingsConfig.barHeight). Clicking outside dismisses it. IPC
// toggle/show/hide drive a `shown` flag; the close is deferred ~240 ms so the
// slide-up animation plays before the surface hides.
//
// All visual structure lives in ModernDashboard.qml (nav + tab content).
// =============================================================================

import Quickshell
import Quickshell.Wayland
import Quickshell.Io

import QtQuick
import "components" as Components
import "config" as Config

ShellRoot {
    id: root
    property bool shown: false

    // =========================================================================
    // IPC — SettingsWindow (bar gear icon / clock)
    // =========================================================================
    IpcHandler {
        id: settingsWindowIpc
        target: "SettingsWindow"

        function toggle() { root.shown ? root.doHide() : root.doShow() }
        function show()   { root.doShow() }
        function hide()   { root.doHide() }
        function openControl(section) {
            root.doShow()
            dashboard.openControlTab(section)
        }
    }

    // =========================================================================
    // IPC — powerMenu overlay (bar PowerIcon / SUPER+P)
    // =========================================================================
    IpcHandler {
        id: powerMenuIpc
        target: "powerMenu"
        function toggle() { powerMenu.showing = !powerMenu.showing }
    }

    function doShow() {
        closeTimer.stop()
        root.shown = true
        panelWindow.visible = true
    }

    function doHide() {
        root.shown = false
        closeTimer.restart()   // let the slide-up finish, then hide the surface
    }

    Timer {
        id: closeTimer
        interval: 260
        onTriggered: panelWindow.visible = false
    }

    // =========================================================================
    // PANEL WINDOW — full-screen transparent overlay
    // =========================================================================
    PanelWindow {
        id: panelWindow
        visible: false

        anchors { top: true; bottom: true; left: true; right: true }
        color: "transparent"
        exclusionMode: ExclusionMode.Ignore

        // Click outside the card dismisses the dashboard.
        MouseArea {
            anchors.fill: parent
            onClicked: root.doHide()
        }

        // =====================================================================
        // Animated dashboard card — drops from the top to just below the bar
        // =====================================================================
        Rectangle {
            id: card
            width: 700
            height: 650
            x: (parent.width - width) / 2
            y: root.shown ? Config.SettingsConfig.barHeight : -(height + 40)
            opacity: root.shown ? 1.0 : 0.0
            color: Config.SettingsConfig.background
            clip: true

            Behavior on y { NumberAnimation { duration: 220; easing.type: Easing.OutCubic } }
            Behavior on opacity { NumberAnimation { duration: 180 } }

            // Absorb clicks inside the card so they don't dismiss the dashboard.
            MouseArea { anchors.fill: parent }

            Components.ModernDashboard {
                anchors.fill: parent
            }
        }
    }

    // =========================================================================
    // POWER MENU — full-screen overlay (toggled via the 'powerMenu' IPC target)
    // =========================================================================
    Components.PowerMenu {
        id: powerMenu
    }
}
import Quickshell.Wayland
import Quickshell.Io
import QtQuick
import "components" as Components
import "config" as Config
